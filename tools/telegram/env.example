# Container sets MCP_HOST/MCP_PORT/MCP_TRANSPORT; this file is secrets + posture only.
MCP_AUTH_ENABLED=0
# MCP_PUBLIC_URL is stamped by the tunnel overlay from the root .env's MCP_DOMAIN;
# set it here only when running outside compose.
#MCP_PUBLIC_URL=https://telegram.<MCP_DOMAIN>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MCP_ALLOWED_GOOGLE_EMAILS=

# --- Telegram (user-account MTProto client; treat like a password) -------------
# API credentials from https://my.telegram.org -> "API development tools".
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Generated ONCE, out-of-band, on a trusted machine (interactive phone login):
#   uvx --from git+https://github.com/chigwell/telegram-mcp telegram-mcp-generate-session
# This string IS full account access -- it never belongs anywhere but here.
TELEGRAM_SESSION_STRING=

# Exposed tool surface. The server defaults to read-only (49 tools; no send/
# delete/join). Widening to 'all' is a deliberate posture change -- pair it with
# MCP_REQUIRE_APPROVAL=1 so writes go through the out-of-band approval gate.
#TELEGRAM_EXPOSED_TOOLS=read-only
