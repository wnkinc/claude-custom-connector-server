MCP_HOST=127.0.0.1
MCP_PORT=8064

MCP_AUTH_ENABLED=0
MCP_PUBLIC_URL=https://hamilton.secure-agentic-engineering.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MCP_ALLOWED_GOOGLE_EMAILS=

# numba JIT cache dir. Under the hardened unit the venv ($HOME) is read-only, so
# pandas_ta's cache=True funcs need a writable cache location or they raise "no locator
# available" at import. The EFFECTIVE setting is in the systemd unit (pandas_ta imports
# before .env loads); this mirrors it for non-systemd runs. Empty = numba default.
NUMBA_CACHE_DIR=/var/lib/mcp-hamilton/numba-cache
