# Container sets MCP_HOST/MCP_PORT/MCP_TRANSPORT; this file is secrets + posture only.
MCP_AUTH_ENABLED=1
# MCP_PUBLIC_URL is stamped by the tunnel overlay from the root .env's MCP_DOMAIN;
# set it here only when running outside compose.
#MCP_PUBLIC_URL=https://browser.example.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MCP_ALLOWED_GOOGLE_EMAILS=

# Gates the noVNC live-view page (any passphrase). UNSET = no live view: the
# entrypoint then never starts x11vnc/websockify (fail closed), and
# browser_live_view reports the view as unavailable.
BROWSER_VIEW_PASSWORD=

# Optional knobs (defaults shown). BROWSER_HEADLESS=1 skips the X/VNC stack and
# runs Chromium headless -- no live view. BROWSER_CAPS trims the engine's opt-in
# tool groups if the full surface is ever too much.
#BROWSER_WIDTH=1280
#BROWSER_HEIGHT=800
#BROWSER_HEADLESS=0
#BROWSER_CAPS=config,devtools,network,pdf,storage,testing,vision
